# ─────────────────────────────────────────────────────────────
# Quiz Platform — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────────────────────

# ── Telegram Bot ─────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=YourBotUsername
BOT_MODE=polling                    # polling or webhook
WEBHOOK_URL=https://yourdomain.com  # required if BOT_MODE=webhook

# ── Database ─────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/quizplatform
DB_USERNAME=quizplatform
DB_PASSWORD=quizplatform

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# ── MinIO ────────────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=quizplatform
MINIO_SECRET_KEY=quizplatform123
MINIO_BUCKET_RECEIPTS=payment-receipts
MINIO_BUCKET_IMPORTS=question-imports

# ── JWT ─────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=./keys/private.pem   # RS256 private key
JWT_PUBLIC_KEY_PATH=./keys/public.pem     # RS256 public key
JWT_EXPIRY_HOURS=24

# ── Business Configuration ──────────────────────────────────
PAYMENT_PRICE=15000          # in UZS
PAYMENT_CARD=8600XXXXXXXXXXXX
PAYMENT_OWNER=Kamron Jumanov
ADMIN_GROUP_ID=-1001234567890        # Telegram group for payment receipts
FORWARD_CHANNEL_ID=-1001234567890   # Telegram channel for unknown messages
ADMIN_IDS=123456789,987654321        # Comma-separated Telegram IDs of super admins

# ── Service URLs (for inter-service calls) ───────────────────
USER_SERVICE_URL=http://localhost:8082
QUIZ_SERVICE_URL=http://localhost:8083
QUESTION_SERVICE_URL=http://localhost:8084
NOTIFICATION_SERVICE_URL=http://localhost:8085
ADMIN_SERVICE_URL=http://localhost:8086
IMPORT_SERVICE_URL=http://localhost:8087

# ── Observability ────────────────────────────────────────────
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
ENVIRONMENT=local

# ── Service Ports ────────────────────────────────────────────
GATEWAY_PORT=8080
TELEGRAM_SERVICE_PORT=8081
USER_SERVICE_PORT=8082
QUIZ_SERVICE_PORT=8083
QUESTION_SERVICE_PORT=8084
NOTIFICATION_SERVICE_PORT=8085
ADMIN_SERVICE_PORT=8086
IMPORT_SERVICE_PORT=8087
