      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "System Active Users (Logins / Activity)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{uri=\"/api/v1/users/register\"}[5m]))",
          "legendFormat": "User Reg / Activity Rate",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "title": "Active Quiz Sessions & Solved Questions",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{uri=\"/api/v1/quiz/answer\"}[5m]))",
          "legendFormat": "Question Submission Rate",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "title": "JVM Heap Memory Usage",
      "type": "timeseries",
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"}",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "title": "RabbitMQ Delivery Queue Traffic",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rabbitmq_queue_messages{queue=~\"notification.*|quiz.*\"}",
          "legendFormat": "{{queue}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
